{
  "name": "next-lite-auth",
  "version": "0.2.2",
  "description": "Lightweight JWT auth for Next.js using static JSON users (no database)",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "peerDependencies": {
    "next": ">=13.0.0",
    "react": ">=18.0.0"
  },
  "dependencies": {
    "jose": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^18.0.0",
    "next": "^14.0.0",
    "react": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitepress": "^1.0.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "author": "amide-init",
  "repository": {
    "type": "git",
    "url": "https://github.com/amide-init/next-lite-auth.git"
  },
  "homepage": "https://github.com/amide-init/next-lite-auth#readme",
  "bugs": {
    "url": "https://github.com/amide-init/next-lite-auth/issues"
  },
  "keywords": [
    "nextjs",
    "auth",
    "jwt",
    "lightweight"
  ],
  "license": "MIT"
}
